# URL of the transcription API service (the FastAPI app in /api)
TRANSCRIPTION_API_URL=http://localhost:8001

# API key — must match the API_KEY set in the api/.env file
TRANSCRIPTION_API_KEY=change-me

# Where the UI backend stores its SQLite DB and uploaded audio.
# Defaults to ./data next to main.py if unset.
# DATA_DIR=/absolute/path/to/data
