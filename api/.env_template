# Required: base directory from which test audio filenames are resolved.
# The API only accepts filenames relative to this path.
AUDIO_BASE_DIR=/path/to/audio/

# Required: API key — all requests must include this as the X-API-Key header.
# Leave blank to disable authentication (development only).
API_KEY=change-me

# Required: HuggingFace token for pyannote/speaker-diarization-3.1.
# Accept the model licence at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: directory containing the finetuned adapter files.
# Expected files: adapter.fry.safetensors and adapter.nld.safetensors.
ADAPTER_DIR=/path/to/models/adapters/

# Required: shared KenLM ARPA file trained on both Frisian and Dutch.
KENLM_MODEL_PATH=/path/to/models/kenlm/mixed_balanced_4gram.arpa

# Required: trained language-ID classifier (.pkl produced by LANG_ID_VM/train_lid.py).
LANG_ID_MODEL_PATH=/path/to/models/lang_id/lid_production_classifier.pkl

# Optional: directory for caching HuggingFace model weights.
# Use an absolute path. Defaults to ~/.cache/huggingface.
MODEL_CACHE_DIR=/path/to/hf_cache

# Optional: transcription tuning (these are the defaults).
MIN_SEGMENT_DUR=0.3
PAD_S=0.1
# BEAM_WIDTH is the pyctcdecode search width. Higher = better quality, slower decoding.
# 50 is fast, 100 is a good default, 200+ for best quality offline.
BEAM_WIDTH=100
